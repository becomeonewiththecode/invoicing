# Copy to `.env` in the SAME directory as `docker-compose-prod.yml`.
# Run all `docker compose` and acme.sh steps from that directory so `.env` resolves correctly.
# Do not commit a real `.env` with secrets. TLS: see tls.md

# --- Host data directory (bind mounts) ---
# docker-compose-build.yml and docker-compose-prod.yml use:
#   ${DEPLOY_DATA_DIR:-./data}
# That means: use the value of DEPLOY_DATA_DIR from this file (or the shell) if set;
# otherwise default to ./data — a folder named "data" next to the compose file.
#
# Examples:
#   DEPLOY_DATA_DIR=./data
#   DEPLOY_DATA_DIR=/var/lib/invoice   # absolute path on the server
#
# Under that directory, create pgdata/, uploads/, acme_webroot/, ssl_certs/ before first up, e.g.:
#   D="${DEPLOY_DATA_DIR:-./data}"
#   mkdir -p "$D/pgdata" "$D/uploads" "$D/acme_webroot" "$D/ssl_certs" && chown -R "$(id -u):$(id -g)" "$D"
DEPLOY_DATA_DIR=./data

# --- JWT tokens (API + portal Bearer tokens) ---
# There is no single JWT_TOKENS variable: the backend uses JWT_SECRET (HMAC signing key) and
# JWT_EXPIRES_IN (access token lifetime). Both are passed to the backend service by docker-compose.
#
# JWT_SECRET: use a long random value in production, e.g.:
#   openssl rand -hex 32
# JWT_EXPIRES_IN: jsonwebtoken expiry string — number + unit (ms, s, m, h, d), e.g. 7d, 24h, 3600s
JWT_SECRET=change-me-use-openssl-rand-hex-32-in-production
JWT_EXPIRES_IN=7d

# --- Seed admin user (backend creates on first startup if missing) ---
# ADMIN_EMAIL: login for the initial admin account (default matches compose).
ADMIN_EMAIL=admin@invoicing.local
# ADMIN_PASSWORD: use a unique secret in every environment — generate e.g.:
#   openssl rand -base64 24
# The line below is a placeholder shape only; replace before deploy (never reuse examples).
ADMIN_PASSWORD=replace-me-openssl-rand-base64-24

# Public hostname for nginx (must match the TLS certificate)
NGINX_SERVER_NAME=clients.example.com

# Compose project name — prefixes containers/networks (not bind-mount paths under DEPLOY_DATA_DIR)
COMPOSE_PROJECT_NAME=invoicing
