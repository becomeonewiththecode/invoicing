# Copy to `.env` in this directory. Docker Compose loads `.env` when you run
# `docker compose` from `deployment/`. Do not commit real `.env` if it contains secrets.
# TLS / nginx: see tls.md

# Public hostname for nginx (must match the TLS certificate)
NGINX_SERVER_NAME=clients.example.com

# Stable Compose project prefix → volumes like ${COMPOSE_PROJECT_NAME}_acme_webroot
COMPOSE_PROJECT_NAME=invoicing
